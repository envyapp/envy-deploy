# PostgreSQL
POSTGRES_USER=envy
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=envy

# JWT signing key — generate a random string of at least 32 characters
# Example: openssl rand -hex 32
SECRET_KEY=change-this-to-a-long-random-string

# First admin account — change before first launch
ENVY_SUPERADMIN_EMAIL=admin@yourcompany.com
ENVY_SUPERADMIN_PASSWORD=change-this-strong-password

# The URL where the web UI will be accessible (used for CORS)
# Example: http://192.168.1.100:3000 or https://envy.yourcompany.com
ENVY_BASE_URL=http://your-server-ip:3000

# Set to true only if serving over HTTPS (enables Secure flag on auth cookies)
COOKIE_SECURE=false
